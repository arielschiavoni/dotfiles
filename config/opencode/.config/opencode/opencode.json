{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-claude-auth@latest"
    // ["opencode-mempalace@0.3.1", {
    //   "mcpCommand": ["uvx", "--from", "mempalace", "python", "-m", "mempalace.mcp_server"],
    //   "disableAutoUpdate": true
    // }]
  ],
  // https://docs.github.com/en/copilot/concepts/billing/copilot-requests
  "enabled_providers": ["github-copilot", "amazon-bedrock", "anthropic"],
  "permission": {
    "playwright_*": "deny",
    "chrome-devtools_*": "deny",
    "awslabs*": "deny",
    "github*": "deny"
  },
  "model": "amazon-bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0",
  "small_model": "amazon-bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0",
  "agent": {
    "plan": {
      "model": "amazon-bedrock/eu.anthropic.claude-sonnet-4-6"
    },
    "build": {
      "model": "amazon-bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0"
    },
    "explore": {
      "model": "amazon-bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0"
    }
  },
  "autoupdate": false,
  "experimental": {
    "disable_paste_summary": true
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--headless"
      ],
      "enabled": false
    },
    "awslabs.aws-documentation-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-documentation-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      },
      "enabled": true
    },
    "awslabs.aws-iac-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-iac-mcp-server@latest"],
      "environment": { "FASTMCP_LOG_LEVEL": "ERROR" },
      "enabled": true
    },
    "awslabs.cloudwatch-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.cloudwatch-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "enabled": true
    },
    "awslabs.billing-cost-management-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.billing-cost-management-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_REGION": "us-east-1"
      },
      "enabled": true
    },
    "awslabs.aws-pricing-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-pricing-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_REGION": "us-east-1"
      },
      "enabled": true
    },
    "awslabs.cloudtrail-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.cloudtrail-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "enabled": true
    },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    // codebase-memory-mcp: High-performance code intelligence engine (https://github.com/DeusData/codebase-memory-mcp)
    // Setup:
    //   1. Install: curl -fsSL https://raw.githubusercontent.com/DeusData/codebase-memory-mcp/main/install.sh | bash -s -- --ui
    //   2. Enable auto-indexing: codebase-memory-mcp config set auto_index true
    //   3. Restart opencode — repo will auto-index on next session
    // Config stored at: ~/.cache/codebase-memory-mcp/_config.db (SQLite, not XDG config)
    "codebase-memory-mcp": {
      "enabled": true,
      "type": "local",
      "command": ["codebase-memory-mcp"]
    }
  }
}
