{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-claude-auth@latest", "oc-tps@latest"],
  // https://docs.github.com/en/copilot/concepts/billing/copilot-requests
  "enabled_providers": [
    "github-copilot",
    "amazon-bedrock",
    "anthropic",
    "ollama"
  ],
  "permission": {
    "playwright_*": "deny",
    "chrome-devtools_*": "deny",
    "awslabs*": "deny",
    "github*": "deny"
  },
  "model": "amazon-bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0",
  // "small_model": "amazon-bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0",
  "small_model": "amazon-bedrock/nvidia.nemotron-super-3-120b",
  "agent": {
    "plan": {
      "model": "amazon-bedrock/eu.anthropic.claude-sonnet-4-6"
    },
    "build": {
      // "model": "amazon-bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0"
      "model": "amazon-bedrock/minimax.minimax-m2.5"
    },
    "explore": {
      // "model": "amazon-bedrock/eu.anthropic.claude-haiku-4-5-20251001-v1:0"
      // "model": "amazon-bedrock/minimax.minimax-m2.5"
      "model": "amazon-bedrock/nvidia.nemotron-super-3-120b"
      // "model": "ollama/gemma4:12b-mlx"
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:12b-mlx": {
          "name": "Gemma 4 12B MLX (local)",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      }
    }
  },
  "autoupdate": false,
  "experimental": {
    "disable_paste_summary": true
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--headless"
      ],
      "enabled": false
    },
    "awslabs.aws-documentation-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-documentation-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      },
      "enabled": true
    },
    "awslabs.aws-iac-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-iac-mcp-server@latest"],
      "environment": { "FASTMCP_LOG_LEVEL": "ERROR" },
      "enabled": true
    },
    "awslabs.cloudwatch-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.cloudwatch-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "enabled": true
    },
    "awslabs.billing-cost-management-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.billing-cost-management-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_REGION": "us-east-1"
      },
      "enabled": true
    },
    "awslabs.aws-pricing-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-pricing-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_REGION": "us-east-1"
      },
      "enabled": true
    },
    "awslabs.cloudtrail-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.cloudtrail-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "enabled": true
    },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    }
  }
}
