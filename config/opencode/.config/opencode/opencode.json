{
  "$schema": "https://opencode.ai/config.json",
  // only allow and show models from github-copilot
  "enabled_providers": ["github-copilot", "amazon-bedrock"],
  "permission": {
    "drawio_*": "deny",
    "playwright_*": "deny",
    "chrome-devtools_*": "deny",
    "awslabs*": "deny"
  },
  // "model": "github-copilot/gpt-5.4-mini",
  // "small_model": "github-copilot/gpt-5.4-mini",
  // "agent": {
  //   "plan": {
  //     "model": "github-copilot/claude-sonnet-4.6"
  //   },
  //   "build": {
  //     "model": "github-copilot/gpt-5.4-mini"
  //   },
  //   "explore": {
  //     "model": "github-copilot/gpt-5.4-mini"
  //   }
  // },
  "model": "amazon-bedrock/anthropic.claude-sonnet-4-6",
  "small_model": "amazon-bedrock/anthropic.claude-haiku-4-5-20251001-v1:0",
  "agent": {
    "plan": {
      "model": "amazon-bedrock/anthropic.claude-sonnet-4-6"
    },
    "build": {
      "model": "amazon-bedrock/anthropic.claude-haiku-4-5-20251001-v1:0"
    },
    "explore": {
      "model": "amazon-bedrock/anthropic.claude-haiku-4-5-20251001-v1:0"
    }
  },
  "autoupdate": false,
  "experimental": {
    "disable_paste_summary": true
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "drawio": {
      "type": "local",
      "command": ["npx", "-y", "drawio-mcp-server", "--editor"],
      "enabled": false
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Basic {env:ATLASSIAN_MCP_AUTH}"
      },
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--headless"
      ],
      "enabled": false
    },
    "awslabs.aws-documentation-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-documentation-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      },
      "enabled": true
    },
    "awslabs.aws-iac-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-iac-mcp-server@latest"],
      "environment": { "FASTMCP_LOG_LEVEL": "ERROR" },
      "enabled": true
    },
    "awslabs.cloudwatch-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.cloudwatch-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "enabled": true
    },
    "awslabs.billing-cost-management-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.billing-cost-management-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_REGION": "us-east-1"
      },
      "enabled": true
    },
    "awslabs.aws-pricing-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-pricing-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_REGION": "us-east-1"
      },
      "enabled": true
    },
    "awslabs.cloudtrail-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.cloudtrail-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "enabled": true
    }
  }
}
