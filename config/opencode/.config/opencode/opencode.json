{
  "$schema": "https://opencode.ai/config.json",
  "tools": {
    "drawio": false,
    "playwright": false,
    "chrome-devtools": false,
    "awslabs*": false
  },
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "autoupdate": false,
  "experimental": {
    "disable_paste_summary": true
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true
    },
    "drawio": {
      "type": "local",
      "command": ["npx", "-y", "drawio-mcp-server", "--editor"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--headless"
      ],
      "enabled": true
    },
    "awslabs.aws-documentation-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-documentation-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      },
      "enabled": true
    },
    "awslabs.aws-iac-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-iac-mcp-server@latest"],
      "environment": { "FASTMCP_LOG_LEVEL": "ERROR" },
      "enabled": true
    },
    "awslabs.cloudwatch-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.cloudwatch-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "enabled": true
    },
    "awslabs.billing-cost-management-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.billing-cost-management-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_REGION": "us-east-1"
      },
      "enabled": true
    },
    "awslabs.aws-pricing-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-pricing-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_REGION": "us-east-1"
      },
      "enabled": true
    },
    "awslabs.cloudtrail-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.cloudtrail-mcp-server@latest"],
      "environment": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "enabled": true
    }
  }
}
