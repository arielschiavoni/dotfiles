{
  "$schema": "https://opencode.ai/config.json",
  "tools": {
    "drawio_*": false,
    "playwright_*": false,
    "awslabs.aws-iac-mcp-server_*": false,
    "awslabs.ccapi-mcp-server_*": false,
    "awslabs.cloudwatch-mcp-server_*": false,
    "awslabs.billing-cost-management-mcp-server_*": false
  },
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "autoupdate": false,
  "experimental": {
    "disable_paste_summary": true
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "drawio": {
      "type": "local",
      "command": ["npx", "-y", "drawio-mcp-server", "--editor"]
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"]
    },
    "awslabs.aws-iac-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-iac-mcp-server@latest"],
      "enabled": false,
      "environment": { "FASTMCP_LOG_LEVEL": "ERROR" }
    },
    "awslabs.ccapi-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.ccapi-mcp-server@latest", "--readonly"],
      "enabled": false,
      "environment": { "FASTMCP_LOG_LEVEL": "ERROR" }
    },
    "awslabs.cloudwatch-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.cloudwatch-mcp-server@latest"],
      "enabled": false,
      "environment": { "FASTMCP_LOG_LEVEL": "ERROR" }
    },
    "awslabs.billing-cost-management-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.billing-cost-management-mcp-server@latest"],
      "enabled": false,
      "environment": { "FASTMCP_LOG_LEVEL": "ERROR", "AWS_REGION": "us-east-1" }
    }
  }
}
